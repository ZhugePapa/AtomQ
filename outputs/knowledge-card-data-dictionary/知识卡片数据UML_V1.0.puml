@startuml 软考刷题App-知识卡片数据模型
' ============================================================
'  软考刷题 App — 知识卡片与学习数据 UML 类图
'  版本: V1.0
'  依据: PRD V1.7 + 数据设计文档 V1.2 + 数据字典改进
'  日期: 2026-05-09
' ============================================================

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam packageFontSize 13
skinparam packageFontStyle bold
skinparam defaultFontName Microsoft YaHei

left to right direction

' ============================================================
'  枚举类型
' ============================================================

enum CardType <<enum>> {
  concept
  process
  comparison
  formula
  definition
}

enum SourceType <<enum>> {
  official
  public
  original
}

enum TargetType <<enum>> {
  point
  question
  paper
}

enum RecordStatus <<enum>> {
  not_start
  doing
  done
}

enum WrongPriority <<enum>> {
  high
  normal
  archived
}

enum TaskType <<enum>> {
  learn
  practice
  wrong_review
}

enum TaskStatus <<enum>> {
  pending
  doing
  done
  skipped
}

enum LoginStatus <<enum>> {
  guest
  login
  vip
}

' ============================================================
'  静态内容层 — JSON + Markdown（CDN 分发，本地缓存）
' ============================================================

package "静态内容层 (JSON + Markdown)" #E8F5E9 {

  class SubjectIndex <<subject_index.json>> {
    + subject_id : string <<PK>>
    + subject_name : string
    + chapters : ChapterSummary[]
    __
    ChapterSummary 内嵌:
    · chapter_id : string
    · title : string
    · card_count : int
  }

  class ChapterMeta <<chapter_meta.json>> {
    + chapter_id : string <<PK>>
    + subject_id : string <<FK, ★ 新增>>
    + title : string
    + description : string
    + sort_no : int
  }

  class KnowledgeCardMeta <<kp_*.json>> {
    + point_id : string <<PK>>
    + subject_id : string <<FK>>
    + chapter_id : string <<FK>>
    + title : string (≤30字)
    + card_type : CardType
    + difficulty : int (1-3)
    + estimated_read_seconds : int
    + has_key_content : bool
    + is_free : bool
    + sort_no : int
    + content_file : string
    __
    关联关系:
    + prerequisite_point_ids : string[]
    + related_point_ids : string[]
    + related_question_ids : string[]
    __
    内容管理与版本:
    + source : string
    + source_type : SourceType
    + author : string
    + reviewer : string
    + created_at : datetime
    + updated_at : datetime
    + version : int
    + schema_version : int <<★ 新增>>
  }

  class Question <<ch_*_questions.json>> {
    + question_id : string <<PK>>
    + subject_id : string <<FK>>
    + chapter_id : string <<FK>>
    + knowledge_point_ids : KnowledgePointRef[] <<★ 细化>>
    + difficulty : int (1-3)
    + year : int
    + stem : text
    + options : OptionItem[] <<★ 细化>>
    + answer : string
    + analysis : text
    + is_free : bool
    + domain_tags : string[]
  }

  class ExamPaper <<★ 新增, V1.5>> {
    + paper_id : string <<PK>>
    + subject_id : string <<FK>>
    + title : string
    + year : int
    + question_ids : string[]
    + is_free : bool
    + total_score : int
  }

  class KnowledgePointRef {
    + point_id : string
    + is_primary : bool
    __
    主知识点权重 60%, 其余均分 40%
  }

  class OptionItem {
    + key : string (A/B/C/D)
    + text : string
  }

  KnowledgeCardMeta *-- KnowledgePointRef : (序列化到 Question)
  Question *-- OptionItem
}

' ============================================================
'  动态数据层 — SQLite（本地 + 云端同步）
' ============================================================

package "动态数据层 (SQLite)" #E3F2FD {

  class User <<★ 新增, users 表>> {
    + user_id : string <<PK>>
    + login_status : LoginStatus
    + subject_id : string <<FK>>
    + exam_date : date
    + weekly_days : int (1-7)
    + daily_minutes : int
  }

  class UserRecord <<user_records>> {
    + record_id : string <<PK>>
    + user_id : string <<FK>>
    + target_type : TargetType
    + target_id : string
    + status : RecordStatus
    + last_position : string
    + answer_time_ms : int
    + updated_at : datetime
    + synced : int (0/1)
  }

  class WrongBook <<wrong_book>> {
    + wrong_id : string <<PK>>
    + user_id : string <<FK>>
    + question_id : string <<FK>>
    + wrong_count : int
    + right_streak : int
    + priority : WrongPriority
    + last_wrong_at : datetime
    + next_review_at : datetime
    + synced : int (0/1)
    __
    艾宾浩斯引擎:
    · 客户端本地计算 next_review_at
    · 服务端纠偏覆盖
    · 连续 3 轮答对 → archived
  }

  class MasteryScore <<mastery_scores>> {
    + user_id : string <<PK, FK>>
    + point_id : string <<PK, FK>>
    + score : int (0-100)
    + updated_at : datetime
    + synced : int (0/1)
    __
    阈值:
    · 0-29: 薄弱
    · 30-59: 学习中
    · 60-79: 已完成
    · 80-100: 已掌握
  }

  class DailyTask <<daily_tasks>> {
    + task_id : string <<PK>>
    + user_id : string <<FK>>
    + task_date : date
    + task_type : TaskType
    + target_id : string
    + target_count : int
    + completed_count : int
    + status : TaskStatus
    + synced : int (0/1)
  }
}

' ============================================================
'  关联关系
' ============================================================

SubjectIndex "1" -- "*" ChapterMeta : subject_index.chapters[]
ChapterMeta "1" -- "*" KnowledgeCardMeta : chapter_id
ChapterMeta "1" -- "*" Question : chapter_id

KnowledgeCardMeta "*" -- "*" KnowledgeCardMeta : prerequisite_point_ids\nrelated_point_ids (自关联)
KnowledgeCardMeta "1" -- "*" Question : related_question_ids
Question "*" -- "*" KnowledgeCardMeta : knowledge_point_ids\n(1→N, 含主知识点权重)

SubjectIndex "1" -- "*" ExamPaper : subject_id
ExamPaper "1" -- "*" Question : question_ids

User "1" -- "*" UserRecord : user_id
User "1" -- "*" WrongBook : user_id
User "1" -- "*" MasteryScore : user_id
User "1" -- "*" DailyTask : user_id

Question "1" -- "*" WrongBook : question_id
KnowledgeCardMeta "1" -- "0..1" MasteryScore : point_id (per user)

UserRecord "0..*" ..> KnowledgeCardMeta : target_type=point
UserRecord "0..*" ..> Question : target_type=question
UserRecord "0..*" ..> ExamPaper : target_type=paper

' ============================================================
'  图例与说明
' ============================================================

note right of KnowledgeCardMeta
  <b>JSON + Markdown 双文件方案</b>
  · JSON: 可查询字段 (Codable 解码)
  · MD:  正文内容 (Markdown 渲染)
  · content_file 字段关联两个文件
  · 同目录存放: kp_*.json ↔ kp_*.md
end note

note right of MasteryScore
  <b>掌握度计算 (PRD 11.2)</b>
  分数 = f(答题对错, 题目难度系数,
           答题耗时系数, 知识点权重)
  受艾宾浩斯遗忘衰减影响
end note

note bottom of WrongBook
  <b>艾宾浩斯复习周期 (PRD 11.8)</b>
  第1轮→1天  第2轮→2天  第3轮→4天
  第4轮→7天  第5轮→15天 第6轮→30天
  连续3轮答对→priority=archived
end note

@enduml
